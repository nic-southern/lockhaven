{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@nms/web": ["./apps/web"],
      "@/*": ["./apps/web/*"],
      "@nms/worker": ["./apps/worker/src/index"],
      "@nms/db": ["./packages/db/src/index"],
      "@nms/db/client": ["./packages/db/src/client"],
      "@nms/db/schema": ["./packages/db/src/schema"],
      "@nms/shared": ["./packages/shared/src/index"],
      "@nms/api-contract": ["./packages/api-contract/src/index"],
      "@nms/auth": ["./packages/auth/src/index"],
      "@nms/auth/server": ["./packages/auth/src/server"],
      "@nms/vpn": ["./packages/vpn/src/index"],
      "@nms/remote-access": ["./packages/remote-access/src/index"],
      "@nms/web/*": ["./apps/web/*"],
      "@nms/worker/*": ["./apps/worker/*"],
      "@nms/db/*": ["./packages/db/*"],
      "@nms/shared/*": ["./packages/shared/*"],
      "@nms/api-contract/*": ["./packages/api-contract/*"],
      "@nms/auth/*": ["./packages/auth/*"],
      "@nms/vpn/*": ["./packages/vpn/*"],
      "@nms/remote-access/*": ["./packages/remote-access/*"]
    }
  }
}
