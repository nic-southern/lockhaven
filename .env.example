APP_ENV=development
PRODUCT_NAME=Lockhaven
APP_BASE_URL=https://app.example.com
DATABASE_URL=postgresql://postgres:replace_me@127.0.0.1:5432/nms_vpn
POSTGRES_PASSWORD=replace_me # openssl rand -hex 16
REDIS_URL=redis://127.0.0.1:6379/0
VPN_PUBLIC_HOSTNAME=vpn.example.com
VPN_PUBLIC_PORT=51820
VPN_CIDR=10.80.0.0/16
VPN_SERVER_IP=10.80.0.1
VPN_SERVER_PUBLIC_KEY=replace_me # generated by scripts/deploy-production.sh for production
VPN_DEFAULT_ALLOWED_IPS=10.80.0.1/32
WIREGUARD_INTERFACE=wg0
VPNCTL_PATH=/usr/local/sbin/vpnctl
REMOTE_ACCESS_PROVIDER=guacamole
GUACAMOLE_BASE_URL=http://127.0.0.1:8080/guacamole/
GUACAMOLE_DATABASE_URL=postgresql://guacamole:replace_me@guacamole-db:5432/guacamole_db
GUACAMOLE_DB_PASSWORD=replace_me # openssl rand -hex 16
ROOT_DOMAIN=example.com
APP_HOSTNAME=app.example.com
GUAC_HOSTNAME=guac.example.com
REMOTE_CREDENTIALS_KEY=replace_me # openssl rand -hex 32
BETTER_AUTH_SECRET=replace_me # openssl rand -hex 32
BETTER_AUTH_URL=https://app.example.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me # openssl rand -hex 16, or leave unset and let the deploy script generate one
ADMIN_NAME=Admin
ADMIN_ROLE=owner
