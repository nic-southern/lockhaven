{
  "name": "@nms/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --dir ../.. build:packages && sh -c 'set -a; . ../../.env; set +a; next dev --turbo'",
    "build": "sh -c 'if [ -f ../../.env ]; then set -a; . ../../.env; set +a; fi; next build'",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nms/api-contract": "workspace:*",
    "@nms/auth": "workspace:*",
    "@nms/db": "workspace:*",
    "@nms/remote-access": "workspace:*",
    "@nms/shared": "workspace:*",
    "@nms/vpn": "workspace:*",
    "@tanstack/react-query": "^5.90.10",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "ioredis": "^5.8.2",
    "lucide-react": "^1.16.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint-config-next": "16.1.7",
    "typescript": "^5.9.3"
  }
