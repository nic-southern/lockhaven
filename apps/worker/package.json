{
  "name": "@nms/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --dir ../.. build:packages && sh -c 'set -a; . ../../.env; set +a; tsx watch src/index.ts'",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/worker/src/index.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nms/api-contract": "workspace:*",
    "@nms/db": "workspace:*",
    "@nms/shared": "workspace:*",
    "@nms/vpn": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "bullmq": "^5.61.2",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint-config-next": "16.1.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
