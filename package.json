{
  "name": "lockhaven",
  "version": "0.0.1",
  "packageManager": "pnpm@10.24.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @nms/web dev",
    "dev:web": "pnpm --filter @nms/web dev",
    "dev:worker": "pnpm --filter @nms/worker dev",
    "db:bootstrap-admin": "pnpm --filter @nms/db db:bootstrap-admin",
    "build:packages": "pnpm --filter @nms/shared build && pnpm --filter @nms/db build && pnpm --filter @nms/auth build && pnpm --filter @nms/vpn build && pnpm --filter @nms/remote-access build && pnpm --filter @nms/api-contract build",
    "build": "pnpm --filter @nms/shared build && pnpm --filter @nms/db build && pnpm --filter @nms/auth build && pnpm --filter @nms/vpn build && pnpm --filter @nms/remote-access build && pnpm --filter @nms/api-contract build && pnpm --filter @nms/worker build && pnpm --filter @nms/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
