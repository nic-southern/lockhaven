{
  "name": "@nms/db",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "default": "./dist/src/client.js"
    },
    "./schema": {
      "types": "./dist/src/schema.d.ts",
      "default": "./dist/src/schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "db:bootstrap-admin": "node scripts/bootstrap-admin.mjs"
  },
  "dependencies": {
    "@nms/shared": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.5",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3"
  }
}
