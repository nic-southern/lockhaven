APP_ENV=production
PRODUCT_NAME=Lockhaven
ROOT_DOMAIN=example.com
APP_HOSTNAME=app.example.com
GUAC_HOSTNAME=guac.example.com
GUACAMOLE_API_SESSION_TIMEOUT=1440
VPN_PUBLIC_HOSTNAME=vpn.example.com
SOC_BASE_URL=https://soc.newmarketsecurity.com
WAZUH_AGENT_ENROLLMENT_PASSWORD=replace_me
ACME_EMAIL=admin@example.com

NAME=management-vpn-prod
ENVIRONMENT=prod
REGION=nyc3
DROPLET_SIZE=s-2vcpu-4gb
IMAGE=ubuntu-24-04-x64
SSH_KEY_NAME=your-key-name
SSH_ALLOWED_CIDRS="0.0.0.0/0 ::/0"
DO_TOKEN=replace_me
# GitHub username used for the remote image pull login.
GHCR_USER=your-github-username
# Personal access token with read access to packages.
GHCR_READ_TOKEN=replace_me

# Admin account refreshed after every production deploy.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me
ADMIN_NAME=Admin
ADMIN_ROLE=owner
